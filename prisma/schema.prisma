// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  user
}

enum Gender {
  female
  male
}

enum Stage {
  regular
  playoffs
  finals
}

enum Status {
  scheduled
  inProgress
  completed
  postPosed
  canceled
}

enum PageStatus {
  draft
  hold
  unpublished
  published
}

enum ShootoutStatus {
  in_progress
  completed
}

enum Alignment {
  left
  center
  right
}

model User {
  id            String   @id @default(uuid())
  name          String?
  username      String?  @unique
  email         String   @unique
  emailVerified Boolean? @map("email_verified")
  imageUrl      String?  @map("image_url")
  imagePublicID String?  @map("image_public_id")
  password      String?

  sessions Session[]
  accounts Account[]

  roles    Role[]  @default([user])
  isActive Boolean @default(false) @map("is_active")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Tournament {
  id            String   @id @default(uuid())
  name          String
  permalink     String
  imageUrl      String?  @map("image_url")
  imagePublicID String?  @map("image_public_id")
  description   String?
  category      String
  gender        Gender   @default(male)
  format        String
  stage         Stage    @default(regular)
  country       String?
  state         String?
  city          String?
  season        String?
  startDate     DateTime @map("start_date")
  endDate       DateTime @map("end_date")
  active        Boolean  @default(false)
  currentWeek   Int?     @default(0) @map("current_week")

  // Relations
  matches     Match[]
  credentials Credential[]
  teams       Team[]
  standings   Standings[]

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([permalink, category, format, gender])
  @@map("tournaments")
}

model Team {
  id            String   @id @default(uuid())
  name          String
  permalink     String
  headquarters  String?
  imageUrl      String?  @map("image_url")
  imagePublicID String?  @map("image_public_id")
  category      String
  format        String
  gender        Gender   @default(male)
  country       String?
  city          String?
  state         String?
  emails        String[] @default([])
  address       String?
  active        Boolean  @default(false)

  // Relations
  coachId          String?           @map("coach_id")
  coach            Coach?            @relation(fields: [coachId], references: [id])
  players          Player[]
  tournamentId     String?           @map("tournament_id")
  tournament       Tournament?       @relation(fields: [tournamentId], references: [id])
  standings        Standings[]
  homeMatches      Match[]           @relation("HomeMatches")
  awayMatches      Match[]           @relation("AwayMatches")
  localShootouts   PenaltyShootout[] @relation("ShootoutLocalTeam")
  visitorShootouts PenaltyShootout[] @relation("ShootoutVisitorTeam")
  wonShootouts     PenaltyShootout[] @relation("ShootoutWinnerTeam")
  penaltyKicks     PenaltyKick[]
  fields           Field[]

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([permalink, category, format])
  @@map("teams")
}

model Field {
  id        String  @id @default(uuid())
  name      String  @db.VarChar()
  city      String? @db.VarChar()
  state     String? @db.VarChar()
  country   String? @db.VarChar()
  address   String? @db.VarChar()
  map       String? @db.VarChar()
  permalink String  @unique()

  // Relationship
  teamId String? @map("team_id")
  team   Team?   @relation(fields: [teamId], references: [id])

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("fields")
}

model Coach {
  id            String  @id @default(uuid())
  name          String
  email         String? @unique
  phone         String?
  age           Int?
  nationality   String?
  imageUrl      String?
  imagePublicID String? @map("image_public_id")
  description   String?
  active        Boolean @default(false)

  // Relations
  teams Team[]

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("coaches")
}

model Player {
  id            String    @id @default(uuid())
  name          String
  email         String?
  phone         String?
  birthday      DateTime?
  nationality   String?
  imageUrl      String?   @map("image_url")
  imagePublicID String?   @map("image_public_id")
  active        Boolean   @default(false)

  // Relations
  credential   Credential?
  teamId       String?       @map("team_id")
  team         Team?         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  penaltyKicks PenaltyKick[]

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("players")
}

model Match {
  id           String    @id @default(uuid())
  localId      String    @map("local_id")
  visitorId    String    @map("visitor_id")
  localScore   Int?      @default(0) @map("local_score")
  visitorScore Int?      @default(0) @map("visitor_score")
  place        String?
  matchDate    DateTime? @map("match_date")
  week         Int?
  referee      String?

  status Status @default(scheduled)

  // Relations
  tournamentId    String           @map("tournament_id")
  tournament      Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  local           Team             @relation("HomeMatches", fields: [localId], references: [id])
  visitor         Team             @relation("AwayMatches", fields: [visitorId], references: [id])
  penaltyShootout PenaltyShootout?

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("matches")
}

model PenaltyShootout {
  id String @id @default(uuid())

  // Match (1–1)
  matchId String @unique @map("match_id")
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  // Local team
  localTeamId String @map("local_team_id")
  localTeam   Team   @relation("ShootoutLocalTeam", fields: [localTeamId], references: [id])

  // Visitor team
  visitorTeamId String @map("visitor_team_id")
  visitorTeam   Team   @relation("ShootoutVisitorTeam", fields: [visitorTeamId], references: [id])

  // Result
  localGoals   Int @default(0) @map("local_goals")
  visitorGoals Int @default(0) @map("visitor_goals")

  // Winner
  winnerTeamId String? @map("winner_team_id")
  winnerTeam   Team?   @relation("ShootoutWinnerTeam", fields: [winnerTeamId], references: [id])

  status ShootoutStatus @default(in_progress)
  kicks  PenaltyKick[]

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([matchId])
  @@map("penalties_shootouts")
}

model PenaltyKick {
  id String @id @default(uuid())

  shootoutId String          @map("shootout_id")
  shootout   PenaltyShootout @relation(fields: [shootoutId], references: [id], onDelete: Cascade)

  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id])

  playerId String? @map("player_id")
  player   Player? @relation(fields: [playerId], references: [id], onDelete: Cascade)

  shooterName String?  @map("shooter_name")
  order       Int
  isGoal      Boolean? @map("is_goal")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([shootoutId, teamId, order])
  @@map("penalty_kicks")
}

model Credential {
  id           String   @id @default(uuid())
  fullName     String   @map("full_name")
  birthdate    DateTime @map("birthdate")
  curp         String   @unique
  position     String
  jerseyNumber Int      @map("jersey_number")

  // Relations
  playerId     String     @unique @map("player_id")
  player       Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  tournamentId String     @map("tournament_id")
  tournament   Tournament @relation(fields: [tournamentId], references: [id])

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("credentials")
}

model Standings {
  id               String @id @default(uuid())
  teamId           String @unique() @map("team_id")
  team             Team   @relation(fields: [teamId], references: [id])
  matchesPlayed    Int    @default(0) @map("matches_played")
  wins             Int    @default(0) @map("wins")
  draws            Int    @default(0) @map("draws")
  losses           Int    @default(0) @map("losses")
  goalsFor         Int    @default(0) @map("goals_for")
  goalsAgainst     Int    @default(0) @map("goals_against")
  goalsDifference  Int    @default(0) @map("goals_difference")
  additionalPoints Int    @default(0) @map("additional_points")
  points           Int    @default(0) @map("points")
  totalPoints      Int    @default(0) @map("total_points")

  // Relations
  tournamentId String     @map("tournament_id")
  tournament   Tournament @relation(fields: [tournamentId], references: [id])

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("standings")
}

model ContactMessage {
  id      String  @id @default(uuid())
  name    String
  email   String
  message String  @db.Text
  read    Boolean @default(false)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("contact_messages")
}

model Gallery {
  id          String   @id @default(uuid())
  title       String   @unique
  permalink   String   @unique
  galleryDate DateTime @map("gallery_date")
  active      Boolean  @default(false)

  // Relations
  images GalleryImage[]

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("gallery")
}

model GalleryImage {
  id            String  @id @default(uuid())
  title         String
  imageUrl      String  @unique
  imagePublicID String  @map("image_public_id")
  active        Boolean @default(false)
  position      Int     @default(0)

  // Relations
  galleryId String  @map("gallery_id")
  gallery   Gallery @relation(fields: [galleryId], references: [id])

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("gallery_image")
}

model CustomPage {
  id             String     @id @default(uuid())
  title          String?
  permalink      String?    @unique
  content        String?    @db.Text
  position       Int?
  seoTitle       String?    @map("seo_title")
  seoDescription String?    @map("seo_description")
  seoRobots      String?    @default("noindex, nofollow") @map("seo_robots")
  status         PageStatus @default(draft)

  // Relations
  images CustomPageImage[]

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("custom_pages")
}

model CustomPageImage {
  id        String   @id @default(uuid())
  imageUrl  String   @map("image_url")
  publicId  String   @map("image_public_id")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  customPageId String     @map("custom_page_id")
  customPage   CustomPage @relation(fields: [customPageId], references: [id], onDelete: Cascade)

  @@map("custom_page_images")
}

model Carousel {
  id           String   @id @default(uuid())
  time         Int      @default(5)
  play         Boolean  @default(false)
  loop         Boolean  @default(false)
  section      String
  showControls Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("carousels")
}

model HeroBanner {
  id            String    @id @default(uuid())
  title         String    @unique @db.VarChar
  description   String    @db.Text
  imageUrl      String    @map("image_url")
  imagePublicId String    @map("image_public_id")
  dataAlignment Alignment @default(left) @map("data_alignment")
  showData      Boolean   @default(false) @map("show_data")
  position      Int       @default(0)
  active        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("hero_banners")
}

model Sponsor {
  id            String    @id @default(uuid())
  name          String    @unique @db.VarChar
  url           String?
  imageUrl      String    @map("image_url")
  imagePublicId String    @map("image_public_id")
  startDate     DateTime? @map("start_date")
  endDate       DateTime? @map("end_date")
  position      Int       @default(0)
  alignment     String
  clicks        Int       @default(0)
  active        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("sponsors")
}

model Announcement {
  id            String   @id @default(uuid())
  title         String   @unique @db.VarChar
  permalink     String   @unique @db.VarChar
  publishedDate DateTime @default(now()) @map("published_date")
  description   String   @db.VarChar
  content       String
  active        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("announcements")
}

model Video {
  id            String   @id @default(uuid())
  title         String   @unique @db.VarChar
  permalink     String   @unique @db.VarChar
  publishedDate DateTime @default(now()) @map("published_date")
  description   String   @db.VarChar
  url           String
  platform      String
  active        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("videos")
}

model GlobalSettings {
  id               Int     @id @default(1)
  // GENERAL
  siteName         String? @map("site_name") @db.VarChar(100)
  logoUrl          String? @map("logo_url") @db.VarChar(255)
  logoPublicId     String? @map("logo_public_id") @db.VarChar(255)
  faviconUrl       String? @map("favicon_url") @db.VarChar(255)
  favIconPublicId  String? @map("favicon_id") @db.VarChar(255)
  organizationName String? @map("organization_name") @db.VarChar(100)
  phone            String? @db.VarChar(150)
  address          String? @db.VarChar(255)
  mapsUrl          String? @map("maps_url") @db.VarChar(255)
  country          String? @default("Mexico") @db.VarChar(50)

  // SOCIAL MEDIA
  facebookUrl  String? @map("facebook_url") @db.VarChar(255)
  twitterXUrl  String? @map("twitter_x_url") @db.VarChar(255)
  instagramUrl String? @map("instagram_url") @db.VarChar(255)
  youtubeUrl   String? @map("youtube_url") @db.VarChar(255)
  tiktokUrl    String? @map("tiktok_url") @db.VarChar(255)
  whatsApp     String? @map("whats_app") @db.VarChar(100)

  // MAINTENANCE MODE
  maintenanceMode    Boolean @default(false) @map("maintenance_mode")
  maintenanceMessage String? @map("maintenance_message") @db.VarChar(255)

  // COLORS
  primaryColor   String? @map("primary_color") @db.VarChar(50)
  secondaryColor String? @map("secondary_color") @db.VarChar(50)
  accentColor    String? @map("accent_color") @db.VarChar(50)

  // ANALYTICS
  googleAnalyticsId String? @map("google_analytics_id") @db.VarChar(255)
  googleTagManager  String? @map("google_tag_manager") @db.VarChar(255)
  metaPixelId       String? @map("meta_pixel_id") @db.VarChar(255)

  // LOCATION
  defaultLanguage String? @default("es") @map("default_language") @db.VarChar(3)
  timeZone        String? @default("America/Mexico_City") @map("time_zone") @db.VarChar(100)

  // EMAIL
  contactEmail String? @map("contact_email") @db.VarChar(255)
  fromEmail    String? @map("from_email") @db.VarChar(255)
  replyToEmail String? @map("reply_to_email") @db.VarChar(255)

  // SEO
  seoSections SeoSection[]

  // TIMESTAMPS
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("global_settings")
}

model SeoSection {
  id          String @id @default(uuid())
  permalink   String @unique
  title       String @db.VarChar(70)
  description String @db.VarChar(165)
  robots      String @default("index, follow") @db.VarChar(20)

  // Relationship
  globalSettingsId Int            @default(1) @map("global_settings_id")
  globalSettings   GlobalSettings @relation(fields: [globalSettingsId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("seo_sections")
}
